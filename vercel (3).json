{
  "version": 2,
  "installCommand": "npm install -g pnpm@10 && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-server build",
  "outputDirectory": "artifacts/api-server/dist",
  "builds": [
    {
      "src": "artifacts/api-server/dist/index.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "artifacts/api-server/dist/index.mjs"
    }
  ]
}
